# Backend host/port
API_HOST=127.0.0.1
API_PORT=5001

# Optional override for match dataset path
# MATCHES_PATH=/absolute/path/to/backend/app/data/matches_current.csv
# TEAM_AVAILABILITY_PATH=/absolute/path/to/backend/app/data/team_availability.csv
# TEAM_NEWS_PATH=/absolute/path/to/backend/app/data/team_news.csv

# Live external data provider (football-data.org style)
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_COMPETITION_CODE=PL
FOOTBALL_API_KEY=your_api_key_here

# Team news provider
# Free current-season option:
TEAM_NEWS_PROVIDER=fpl
TEAM_NEWS_SOURCE_LABEL=fpl
TEAM_NEWS_FPL_BASE_URL=https://fantasy.premierleague.com/api

# API-Football / API-Sports option (provider=api-football):
TEAM_NEWS_API_BASE_URL=https://v3.football.api-sports.io
TEAM_NEWS_API_KEY=your_team_news_api_key_here
TEAM_NEWS_LEAGUE_ID=39
TEAM_NEWS_SEASON_START_YEAR=2025
# Optional if you use RapidAPI proxy:
# TEAM_NEWS_RAPIDAPI_HOST=api-football-v1.p.rapidapi.com
# TEAM_NEWS_RAPIDAPI_KEY=your_rapidapi_key_here

# Prediction model controls
MODEL_TRAINING_YEARS=5
MODEL_FORM_WINDOW=5
MODEL_H2H_WINDOW=5
MODEL_RF_TREES=350
MODEL_RF_MIN_SAMPLES_SPLIT=8
MODEL_RF_MAX_DEPTH=0

# Model artifact cache (speeds up cold start by reusing trained model bundle)
MODEL_ARTIFACT_ENABLED=true
# MODEL_ARTIFACT_PATH=/absolute/path/to/backend/app/data/model_bundle.pkl
